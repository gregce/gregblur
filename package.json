{
  "name": "gregblur",
  "version": "0.1.0",
  "description": "High-quality WebGL2 background blur for video streams. Confidence masks, joint bilateral filtering, mask-weighted blur, and temporal smoothing — the full Google Meet technique stack in a standalone library.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./livekit": {
      "types": "./dist/adapters/livekit.d.ts",
      "import": "./dist/adapters/livekit.js"
    },
    "./raw": {
      "types": "./dist/adapters/raw.d.ts",
      "import": "./dist/adapters/raw.js"
    },
    "./detect": {
      "types": "./dist/detect.d.ts",
      "import": "./dist/detect.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gregce/gregblur"
  },
  "bugs": {
    "url": "https://github.com/gregce/gregblur/issues"
  },
  "homepage": "https://github.com/gregce/gregblur#readme",
  "keywords": [
    "background-blur",
    "video",
    "webgl2",
    "segmentation",
    "mediapipe",
    "webrtc",
    "livekit",
    "virtual-background",
    "google-meet",
    "blur",
    "background-removal",
    "video-processing"
  ],
  "peerDependencies": {
    "livekit-client": "^2.1.0"
  },
  "peerDependenciesMeta": {
    "livekit-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "beautiful-mermaid": "^1.1.3",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "livekit-client": "^2.16.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.11.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,mjs}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts' '*.json' '*.md' 'docs/**/*.md'",
    "format:check": "prettier --check 'src/**/*.ts' '*.json' '*.md' 'docs/**/*.md'",
    "demo": "npm run build && node demo/serve.mjs",
    "demo:serve": "node demo/serve.mjs",
    "docs": "node docs/render-diagrams.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  }
}
